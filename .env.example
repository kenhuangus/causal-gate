AGENTFLIGHT_DB=data/agentflight.db
PORT=8080
AGENTFLIGHT_DEMO_MODE=true
# Required only when demo mode is disabled for a private developer deployment:
# AGENTFLIGHT_ADMIN_TOKEN=
# Optional live semantic analysis, never needed for the deterministic demo:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.6
# AGENTFLIGHT_LIVE_ANALYSIS_ENABLED=false
# AGENTFLIGHT_LIVE_ANALYSIS_LIMIT=3
# Only for a deterministic-only verification profile:
# AGENTFLIGHT_RECORDED_ANALYSIS_OPTIONAL=true
