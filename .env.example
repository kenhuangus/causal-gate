CAUSALGATE_DB=data/causalgate.db
PORT=8080
CAUSALGATE_DEMO_MODE=true
# Required only when demo mode is disabled for a private developer deployment:
# CAUSALGATE_ADMIN_TOKEN=
# Optional self-hosted live semantic analysis. The public judge service uses
# an ephemeral per-request BYOK header and has no shared OpenAI credential:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.6-sol
# CAUSALGATE_LIVE_ANALYSIS_ENABLED=false
# CAUSALGATE_LIVE_ANALYSIS_LIMIT=3
# Required only for private issuance and runtime verification of signed intent grants:
# CAUSALGATE_GRANT_SIGNING_KEY=replace-with-at-least-32-random-bytes
# Required for authenticated multi-fixture assurance-suite attestations:
# CAUSALGATE_ATTESTATION_KEY=replace-with-at-least-32-random-bytes
# CAUSALGATE_RUNNER_IDENTITY=cloud-build-causalgate
# CAUSALGATE_SOURCE_REVISION=git-commit-sha
# Only for a deterministic-only verification profile:
# CAUSALGATE_RECORDED_ANALYSIS_OPTIONAL=true
